---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  current?: string;
}

const {
  title,
  description = "입점부터 매출까지, 이커머스의 모든 문제, 한 곳에서. 6대 모듈 × 10개 매체 × 4가지 비용 구조로 풀스택 운영하는 골드넥스 커머스 솔루션.",
  current,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | 골드넥스 커머스 솔루션</title>
    <meta name="description" content={description} />
    
    <meta property="og:title" content={`${title} | 골드넥스 커머스 솔루션`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ko_KR" />
    
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "골드넥스 커머스 솔루션",
      "alternateName": "Goldenax Commerce Solution",
      "url": "https://ds2nerd.github.io",
      "logo": "https://ds2nerd.github.io/goldenax-logo.png",
      "description": description,
      "sameAs": [],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "nb@goldenax.co.kr",
        "contactType": "Sales",
        "areaServed": "KR",
        "availableLanguage": ["Korean"]
      }
    })} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header current={current} />
    <main>
      <slot />
    </main>
    <Footer />
    
    <!-- 스크롤 진입 애니메이션 -->
    <script is:inline>
      document.body.classList.add("js");
      function initFadeUp() {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });
        document.querySelectorAll(".fade-up").forEach(function (el) {
          observer.observe(el);
        });
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initFadeUp);
      } else {
        initFadeUp();
      }
    </script>
  </body>
</html>
