---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  current?: string;
}

const {
  title,
  description = "입점부터 매출까지, 이커머스의 모든 문제, 한 곳에서. 6대 모듈 × 10개 매체 × 4가지 비용 구조로 풀스택 운영하는 골드넥스 커머스 솔루션.",
  current,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | 골드넥스 커머스 솔루션</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | 골드넥스 커머스 솔루션`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ko_KR" />
    
    <!-- Schema.org Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "골드넥스 커머스 솔루션",
      "alternateName": "Goldenax Commerce Solution",
      "url": "https://goldenax.co.kr",
      "logo": "https://goldenax.co.kr/logo.png",
      "description": description,
      "sameAs": [],
"contactPoint": {
  "@type": "ContactPoint",
  "email": "nb@goldenax.co.kr",
  "contactType": "Sales",
  "areaServed": "KR",
  "availableLanguage": ["Korean"]
}
    })} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header current={current} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
