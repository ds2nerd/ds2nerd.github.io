---
const year = new Date().getFullYear();
---

<footer class="bg-ink-black text-white mt-20">
  <div class="container-page py-14">
    <div class="grid lg:grid-cols-4 gap-10">
      <!-- 브랜드 -->
      <div class="lg:col-span-1">
        <div class="font-en font-bold text-xl text-red tracking-wide-en mb-2">GOLDENAX</div>
        <div class="font-bold text-lg mb-3">골드넥스 커머스 솔루션</div>
        <p class="text-sm text-white/60 leading-relaxed">
          입점부터 매출까지, 이커머스의<br />
          모든 문제, 한 곳에서.
        </p>
      </div>
      
      <!-- 사이트맵 -->
      <div class="lg:col-span-2 grid grid-cols-2 sm:grid-cols-3 gap-6 text-sm">
        <div>
          <div class="font-bold text-white/90 mb-3">솔루션</div>
          <ul class="space-y-2 text-white/60">
            <li><a href="/solution/" class="hover:text-red">솔루션 소개</a></li>
            <li><a href="/who/" class="hover:text-red">솔루션 진단</a></li>
            <li><a href="/pricing/" class="hover:text-red">비용 구조</a></li>
            <li><a href="/media/" class="hover:text-red">매체 라인업</a></li>
          </ul>
        </div>
        <div>
          <div class="font-bold text-white/90 mb-3">신뢰</div>
          <ul class="space-y-2 text-white/60">
            <li><a href="/cases/" class="hover:text-red">사례</a></li>
            <li><a href="/process/" class="hover:text-red">운영 프로세스</a></li>
            <li><a href="/about/" class="hover:text-red">회사 소개</a></li>
          </ul>
        </div>
        <div>
          <div class="font-bold text-white/90 mb-3">문의</div>
          <ul class="space-y-2 text-white/60">
            <li><a href="/contact/" class="hover:text-red">무료 상담 신청</a></li>
            <li><span class="text-white/40">평일 10:00 ~ 18:00</span></li>
          </ul>
        </div>
      </div>
      
      <!-- 회사 정보 -->
      <div class="lg:col-span-1 text-sm">
        <div class="font-bold text-white/90 mb-3">Contact</div>
        <ul class="space-y-2 text-white/60">
          <li>이메일 : nb@goldenax.co.kr</li>
          <li class="text-white/40 text-xs">모든 문의는 이메일로 받습니다</li>
        </ul>
      </div>
    </div>
    
    <!-- 사업자 정보 (법적 권장) -->
    <div class="border-t border-white/10 mt-10 pt-6">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 text-xs text-white/50 mb-6">
        <div>
          <span class="text-white/40">상호</span>  
          <span class="ml-2 text-white/70">골드넥스 (GOLDENAX)</span>
        </div>
        <div>
          <span class="text-white/40">대표자</span>  
          <span class="ml-2 text-white/70">김성모</span>
        </div>
        <div>
          <span class="text-white/40">사업자등록번호</span>  
          <span class="ml-2 text-white/70">211-88-46910</span>
        </div>
        <div>
          <span class="text-white/40">이메일</span>  
          <span class="ml-2 text-white/70">nb@goldenax.co.kr</span>
        </div>
      </div>
      <div class="text-xs text-white/40">
        <span class="text-white/40">소재지</span>  
        <span class="ml-2 text-white/60">서울특별시 성동구 상원길 62, 6층</span>
      </div>
    </div>
    
    <!-- 저작권 & 법적 링크 -->
    <div class="border-t border-white/10 mt-6 pt-6 flex flex-col sm:flex-row justify-between gap-4 text-xs text-white/40">
      <div>
        © {year} GOLDENAX Co., Ltd. All rights reserved.
      </div>
      <div class="flex gap-5">
        <a href="/privacy/" class="hover:text-white">개인정보처리방침</a>
        <a href="/terms/" class="hover:text-white">이용약관</a>
      </div>
    </div>
  </div>
</footer>
