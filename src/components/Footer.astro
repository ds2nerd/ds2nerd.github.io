        <div>
          <div class="font-bold text-white/90 mb-3">🎯 솔루션</div>
          <ul class="space-y-2 text-white/60">
            <li><a href="/solution/" class="hover:text-red transition-colors">솔루션 소개</a></li>
            <li><a href="/who/" class="hover:text-red transition-colors">솔루션 진단</a></li>
