---
interface Props {
  title?: string;
  sub?: string;
  primary?: string;
  primaryHref?: string;
  secondary?: string;
  secondaryHref?: string;
}
const {
  title = "어떤 단계에 계신가요? 1분 진단으로 최적 솔루션을 찾아드립니다.",
  sub = "30분 ~ 1시간 상담으로 현재 단계를 진단하고, 5~7영업일 이내 맞춤 견적을 제공해드립니다.",
  primary = "무료 진단 시작하기",
  primaryHref = "/who/",
  secondary = "1:1 상담 신청",
  secondaryHref = "/contact/",
} = Astro.props;
---

<section class="bg-bg-light py-16 mt-20">
  <div class="container-page text-center">
    <h2 class="text-2xl sm:text-3xl font-black text-ink-black leading-tight mb-4">
      {title}
    </h2>
    <p class="text-sm sm:text-base text-ink-body max-w-2xl mx-auto mb-8">
      {sub}
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href={primaryHref} class="btn-primary">{primary} →</a>
      <a href={secondaryHref} class="btn-secondary">{secondary}</a>
    </div>
  </div>
</section>
