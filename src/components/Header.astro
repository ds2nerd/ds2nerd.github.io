---
const { current } = Astro.props;
const navItems = [
  { href: "/solution/", label: "솔루션" },
  { href: "/who/", label: "솔루션 진단" },
  { href: "/pricing/", label: "비용" },
  { href: "/cases/", label: "사례" },
  { href: "/media/", label: "매체" },
  { href: "/process/", label: "프로세스" },
  { href: "/about/", label: "회사 소개" },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 transition-all">
  <div class="container-page flex items-center justify-between h-16">
    <a href="/" class="flex items-center transition-transform hover:scale-105">
      <img src="/goldenax-logo.png" alt="골드넥스 커머스 솔루션" class="h-[22px] w-auto" />
    </a>
    
    <nav class="hidden lg:flex items-center gap-6">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class={`nav-link ${current === item.href ? "active text-red" : "text-ink-body hover:text-red"}`}
        >
          {item.label}
        </a>
      ))}
    </nav>
    
    <a href="/contact/" class="btn-primary !py-2 !px-4 !text-sm">
      <span>📧</span>
      무료 상담
      <span class="arrow-icon">→</span>
    </a>
    
    <button id="mobile-menu-toggle" class="lg:hidden text-ink-dark p-2 transition-colors hover:text-red" aria-label="메뉴 열기">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 6h18M3 12h18M3 18h18"/>
      </svg>
    </button>
  </div>
  
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    <div class="container-page py-4 flex flex-col gap-3">
      {navItems.map(item => (
        <a href={item.href} class={`text-sm font-medium transition-colors ${current === item.href ? "text-red" : "text-ink-body hover:text-red"}`}>
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script is:inline>
  var toggle = document.getElementById("mobile-menu-toggle");
  var menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", function () {
      menu.classList.toggle("hidden");
    });
  }
</script>
