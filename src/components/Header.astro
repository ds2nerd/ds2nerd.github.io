---
const { current } = Astro.props;
const navItems = [
  { href: "/solution/", label: "솔루션" },
  { href: "/who/", label: "누구를 위한 솔루션" },
  { href: "/pricing/", label: "비용" },
  { href: "/cases/", label: "사례" },
  { href: "/media/", label: "매체" },
  { href: "/process/", label: "프로세스" },
  { href: "/about/", label: "회사 소개" },
  { href: "/blog/", label: "블로그" },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="container-page flex items-center justify-between h-16">
    <a href="/" class="flex items-baseline gap-2">
      <span class="font-en font-bold text-red text-lg tracking-wide-en">GOLDENAX</span>
      <span class="hidden sm:inline text-sm text-ink-mute">커머스 솔루션</span>
    </a>
    
    <nav class="hidden lg:flex items-center gap-6">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class={`text-sm font-medium transition-colors ${current === item.href ? "text-red" : "text-ink-body hover:text-red"}`}
        >
          {item.label}
        </a>
      ))}
    </nav>
    
    <a href="/contact/" class="btn-primary !py-2 !px-4 !text-sm">
      무료 상담 신청
    </a>
    
    <!-- 모바일 메뉴 토글 -->
    <button id="mobile-menu-toggle" class="lg:hidden text-ink-dark p-2" aria-label="메뉴 열기">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 6h18M3 12h18M3 18h18"/>
      </svg>
    </button>
  </div>
  
  <!-- 모바일 메뉴 -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    <div class="container-page py-4 flex flex-col gap-3">
      {navItems.map(item => (
        <a href={item.href} class={`text-sm font-medium ${current === item.href ? "text-red" : "text-ink-body"}`}>
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => menu?.classList.toggle("hidden"));
</script>
