---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBlock from "../components/CtaBlock.astro";

// 잘못된 경로 접속 시 안내할 핵심 페이지 3개
const recommendedPages = [
  {
    href: "/",
    eyebrow: "HOME",
    title: "메인 페이지",
    desc: "골드넥스 커머스 솔루션 소개부터 시작해보세요",
    emoji: "🏠",
    accent: "border-red",
  },
  {
    href: "/solution/",
    eyebrow: "SOLUTION",
    title: "솔루션 전체 보기",
    desc: "6대 모듈 × 10개 매체 × 4가지 비용 구조",
    emoji: "🎯",
    accent: "border-conversion",
  },
  {
    href: "/who/",
    eyebrow: "DIAGNOSIS",
    title: "4유형 진단",
    desc: "어떤 단계에 계신지 1분 진단으로 확인",
    emoji: "🧭",
    accent: "border-asset",
  },
];

// 잘못 입력했을 가능성이 높은 주요 페이지들 (드롭다운/링크 형식)
const allPages = [
  { label: "🎯 솔루션", href: "/solution/" },
  { label: "🧭 진단", href: "/who/" },
  { label: "💰 가격 옵션", href: "/pricing/" },
  { label: "📂 사례", href: "/cases/" },
  { label: "📡 매체 라인업", href: "/media/" },
  { label: "⚙️ 운영 프로세스", href: "/process/" },
  { label: "🏢 회사 소개", href: "/about/" },
  { label: "📧 문의하기", href: "/contact/" },
];
---

<BaseLayout
  title="페이지를 찾을 수 없습니다"
  description="요청하신 페이지를 찾을 수 없습니다. 골드넥스 커머스 솔루션의 다른 페이지를 확인해보세요."
>
  <!-- 1. 메인 에러 섹션 -->
  <section class="bg-gradient-soft py-20 lg:py-28 relative overflow-hidden min-h-[60vh] flex items-center">
    <!-- 배경 장식 -->
    <div class="absolute top-10 right-10 w-32 h-32 bg-red/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 left-10 w-40 h-40 bg-red/5 rounded-full blur-3xl"></div>
    <div class="absolute top-0 right-0 w-3 h-full bg-red"></div>
    
    <div class="container-page max-w-4xl relative text-center">
      <!-- 404 표시 -->
      <div class="fade-up">
        <div class="font-en text-[120px] sm:text-[180px] font-black leading-none text-red opacity-90 mb-4 tracking-tight">
          404
        </div>
      </div>
      
      <!-- 메인 메시지 -->
      <div class="fade-up fade-up-delay-1">
        <div class="section-eyebrow justify-center mb-4" style="display: inline-flex;">
          🧭 PAGE NOT FOUND
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-ink-black mb-4 leading-tight">
          요청하신 페이지를 찾을 수 없습니다
        </h1>
        <p class="text-base sm:text-lg text-ink-body max-w-2xl mx-auto leading-relaxed">
          주소를 잘못 입력하셨거나, 페이지가 삭제·이동되었을 수 있습니다.<br />
          아래 추천 페이지에서 원하시는 정보를 찾아보세요.
        </p>
      </div>
      
      <!-- 빠른 액션 버튼 -->
      <div class="fade-up fade-up-delay-2 mt-10 flex flex-wrap items-center justify-center gap-3">
        <a href="/" class="btn-primary inline-flex items-center gap-2">
          <span>🏠</span>
          <span>메인으로 돌아가기</span>
        </a>
        <button
          type="button"
          onclick="history.back()"
          class="btn-secondary inline-flex items-center gap-2"
        >
          <span>←</span>
          <span>이전 페이지로</span>
        </button>
      </div>
    </div>
  </section>

  <!-- 2. 추천 페이지 3개 -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="container-page max-w-5xl">
      <div class="fade-up text-center mb-12">
        <div class="section-eyebrow justify-center" style="display: inline-flex;">✨ RECOMMENDED</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mt-3">이런 페이지는 어떠세요?</h2>
      </div>
      
      <div class="grid sm:grid-cols-3 gap-4 lg:gap-6">
        {recommendedPages.map((p, i) => (
          <a
            href={p.href}
            class={`group block bg-white border-2 ${p.accent} rounded-md p-6 lg:p-8 card-hover fade-up fade-up-delay-${i + 1}`}
          >
            <div class="text-5xl mb-4">{p.emoji}</div>
            <div class="font-en text-red text-xs font-bold tracking-wide-en mb-2">
              {p.eyebrow}
            </div>
            <div class="text-lg lg:text-xl font-black text-ink-black mb-2">
              {p.title}
            </div>
            <div class="text-sm text-ink-body leading-relaxed mb-4">
              {p.desc}
            </div>
            <div class="inline-flex items-center gap-1 text-sm font-bold text-red link-slide">
              <span>이동하기</span>
              <span class="arrow-icon">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. 전체 페이지 목록 (사이트맵) -->
  <section class="py-16 lg:py-20 bg-bg-light">
    <div class="container-page max-w-4xl">
      <div class="fade-up text-center mb-10">
        <div class="section-eyebrow justify-center" style="display: inline-flex;">🗺️ SITEMAP</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mt-3 mb-3">전체 페이지 보기</h2>
        <p class="text-sm text-ink-mute">찾고 계셨던 페이지가 아래 목록에 있을 수도 있어요.</p>
      </div>
      
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 fade-up">
        {allPages.map((p) => (
          <a
            href={p.href}
            class="bg-white border border-gray-200 rounded-md px-4 py-3 text-center text-sm font-medium text-ink-dark hover:border-red hover:text-red transition-colors"
          >
            {p.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. CTA — 직접 문의 -->
  <CtaBlock 
    title="찾으시는 정보가 없으신가요?"
    sub="직접 문의 주시면 빠르게 도와드리겠습니다. 1:1 컨설팅을 통해 맞춤 솔루션을 안내해드립니다."
    primary="문의하기"
    primaryHref="/contact/"
    secondary="회사 소개 보기"
    secondaryHref="/about/"
  />
</BaseLayout>
