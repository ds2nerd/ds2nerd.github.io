---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CtaBlock from "../../../components/CtaBlock.astro";

const caseData = {
  brand: "미스터밀크",
  category: "F&B",
  emoji: "🥛",
  tagline: "정기구독 모델 + 옴니채널 효율화",
  period: "9개월 운영",
  startDate: "2025년 7월",
  modules: ["e커머스 마케팅", "몰 운영", "판매 촉진", "운영관리"],
  channels: ["자사몰", "네이버 스마트스토어", "쿠팡", "마켓컬리", "SSG"],
  options: "옵션 2 (월 정액) + 옵션 3 (매체 단독)",
};

const background = [
  "유제품 카테고리 자체 브랜드 운영. 기존 5개 채널에서 일반 판매 중",
  "재구매율은 양호하나 신규 고객 확보 비용 상승 부담",
  "채널마다 가격·재고 관리가 분산되어 운영 비효율 발생",
  "정기구독 모델 도입 검토 중이나 자체 구축 인프라 부재",
];

const challenges = [
  { title: "옴니채널 운영 분산", desc: "5개 채널 가격·재고·정산이 각각 분리되어 인하우스 부담 가중" },
  { title: "신규 고객 확보 한계", desc: "광고 ROAS 하락 추세, 단발성 구매 의존 구조" },
  { title: "정기구독 기반 부재", desc: "재구매 데이터는 있지만 자동화된 구독 시스템 없음" },
  { title: "정산 검증 리소스 부담", desc: "월말 5개 채널 정산 데이터 수동 대조에 인력 소진" },
];

const approach = [
  {
    phase: "Phase 1", title: "옴니채널 운영 표준화 (1~3개월)", emoji: "⚙️",
    items: [
      "5개 채널 통합 운영 도구 도입 — 사방넷 + 자체 ERP 연동",
      "가격 정합성 자동 모니터링 시스템 구축 (채널별 가격 ±1% 알림)",
      "재고 실시간 동기화 (5분 간격) — 채널별 품절·과재고 0건",
      "정산 검증 자동화 — 수수료·반품·환불 데이터 일괄 매칭",
    ],
  },
  {
    phase: "Phase 2", title: "정기구독 모델 런칭 (3~6개월)", emoji: "🔄",
    items: [
      "자사몰 정기구독 시스템 구축 (월·격주·주 단위 선택)",
      "정기구독 전용 가격 정책 설계 — 일반가 대비 12~18% 할인",
      "구독자 전용 콘텐츠 (월간 뉴스레터·신제품 우선 알림)",
      "이탈 방지 워크플로우 — 3개월 연속 구독 시 사은품 발송",
    ],
  },
  {
    phase: "Phase 3", title: "매체 ROAS 최적화 (3~9개월)", emoji: "📊",
    items: [
      "매체별 ROAS 정량 비교 → 효율 매체 예산 70% 집중",
      "네이버 쇼핑검색광고 + 쿠팡 CPC 입찰 최적화",
      "인플루언서 체험단 — 정기구독 유입 전용 코드 운영",
      "리타겟팅 캠페인 — 1회 구매자 → 정기구독 전환 워크플로우",
    ],
  },
];

const results = [
  { label: "정기구독 회원", value: "월 300명+", note: "신규 가입", emoji: "🔄" },
  { label: "재구매율", value: "62%", note: "전체 평균", emoji: "♻️" },
  { label: "운영 채널", value: "5개", note: "통합 운영 안정화", emoji: "🛒" },
  { label: "광고 ROAS", value: "평균 4.5", note: "효율 매체 집중 후", emoji: "📊" },
];

const beforeAfter = [
  { label: "정기구독 시스템", before: "미구축", after: "월 300명+ 신규 가입" },
  { label: "재구매율", before: "약 38%", after: "62%" },
  { label: "채널 가격 정합성", before: "수동 관리 (오차 발생)", after: "자동 모니터링 (오차 0)" },
  { label: "정산 검증 시간", before: "월 40시간+", after: "월 5시간 미만" },
  { label: "광고 ROAS", before: "평균 2.8", after: "평균 4.5" },
];

const insights = [
  {
    quote: "옴니채널 통합이 가장 큰 변화였습니다. 채널별로 흩어져 있던 운영 부담이 한 곳에서 관리되니까 인력 활용이 완전히 달라졌어요.",
    role: "대표",
  },
  {
    quote: "정기구독 도입 후 매출 예측 가능성이 크게 올라갔습니다. 재고·생산 계획이 안정화되면서 운영 전반의 효율이 동반 상승했어요.",
    role: "운영 총괄",
  },
];

const relatedCases = [
  { slug: "bongpo", brand: "봉포머구리집", category: "F&B", emoji: "🍱", tagline: "지역 노포의 전국 온라인 진입" },
  { slug: "serabloom", brand: "세라블룸", category: "건강기능식품", emoji: "💊", tagline: "광고법 컴플라이언스 + SEO 효율 확보" },
];
---

<BaseLayout
  title={`${caseData.brand} 사례 — ${caseData.tagline}`}
  description={`${caseData.brand} 운영 사례. ${caseData.period}, 정기구독 월 300명+ 신규, 재구매율 62%, ROAS 4.5 달성.`}
  current="/cases/"
>
  <section class="bg-gradient-soft py-16 lg:py-20 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-3 h-full bg-red"></div>
    <div class="container-page max-w-5xl relative">
      <div class="flex items-center gap-2 text-sm mb-6 fade-up">
        <a href="/cases/" class="text-ink-mute hover:text-red transition-colors">← 사례 목록</a>
      </div>
      <div class="grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-7 fade-up">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-5xl">{caseData.emoji}</div>
            <div class="font-en text-red text-sm font-bold tracking-wide-en">{caseData.category} CASE</div>
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-ink-black mb-4 leading-tight">{caseData.brand}</h1>
          <p class="text-lg lg:text-xl text-ink-body mb-6">{caseData.tagline}</p>
          <div class="flex flex-wrap gap-2 mb-6">
            {caseData.modules.map(m => (
              <span class="text-xs bg-white text-ink-body px-3 py-1.5 rounded-full border border-gray-200">▸ {m}</span>
            ))}
          </div>
          <div class="grid grid-cols-3 gap-4 text-sm">
            <div>
              <div class="text-xs text-ink-mute mb-1">📅 운영 기간</div>
              <div class="font-bold text-red">{caseData.period}</div>
            </div>
            <div>
              <div class="text-xs text-ink-mute mb-1">🚀 시작 시점</div>
              <div class="font-bold text-ink-dark">{caseData.startDate}</div>
            </div>
            <div>
              <div class="text-xs text-ink-mute mb-1">💎 비용 구조</div>
              <div class="font-bold text-ink-dark text-xs">{caseData.options}</div>
            </div>
          </div>
        </div>
        <div class="lg:col-span-5 fade-up fade-up-delay-2">
          <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
            <div class="text-5xl mb-2 opacity-30">🖼️</div>
            <div class="text-sm font-bold text-ink-mute">메인 이미지</div>
            <div class="text-xs text-ink-light mt-1">hero.jpg (1600 × 900px)</div>
            <div class="text-xs text-ink-light">/public/cases/mrmilk/</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up">
        <div class="section-eyebrow">📊 RESULTS</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">정량 결과</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {results.map((r, i) => (
          <div class={`stat-card bg-white border-2 border-red rounded-md p-6 text-center card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="text-3xl mb-3">{r.emoji}</div>
            <div class="text-xs font-bold text-ink-mute mb-2">{r.label}</div>
            <div class="stat-number text-2xl sm:text-3xl font-black text-red mb-2">{r.value}</div>
            <div class="text-xs text-ink-light">{r.note}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">📋 BACKGROUND</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">클라이언트 배경</h2>
      </div>
      <div class="bg-white rounded-md p-6 lg:p-8 mb-8 fade-up">
        <div class="text-sm font-bold text-red mb-4 flex items-center gap-2">
          <span>🥛</span> 클라이언트 상황
        </div>
        <ul class="space-y-3">
          {background.map(b => (
            <li class="text-sm text-ink-body flex gap-2">
              <span class="text-red font-bold flex-shrink-0">▸</span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="fade-up">
        <div class="text-sm font-bold text-red mb-4 flex items-center gap-2">
          <span>⚠️</span> 핵심 도전 과제
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          {challenges.map((c, i) => (
            <div class={`bg-white border-l-[3px] border-red p-5 rounded-r-md card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
              <div class="text-base font-bold text-ink-dark mb-2">{c.title}</div>
              <div class="text-sm text-ink-body leading-relaxed">{c.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">🎯 OUR APPROACH</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">우리의 접근</h2>
      </div>
      <div class="space-y-8">
        {approach.map((p, i) => (
          <div class={`bg-bg-card border-l-[3px] border-red p-6 lg:p-8 rounded-r-md card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="flex items-center gap-4 mb-5">
              <div class="icon-circle-red">{p.emoji}</div>
              <div>
                <div class="font-en text-red text-xs font-bold tracking-wide-en mb-1">{p.phase}</div>
                <h3 class="text-lg lg:text-xl font-bold text-ink-dark">{p.title}</h3>
              </div>
            </div>
            <ul class="space-y-2">
              {p.items.map(it => (
                <li class="text-sm text-ink-body flex gap-2">
                  <span class="text-red font-bold flex-shrink-0">▸</span>
                  <span>{it}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up">
        <div class="section-eyebrow">📸 GALLERY</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">운영 화면 · 콘텐츠 샘플</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="aspect-square bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300 fade-up fade-up-delay-1">
          <div class="text-5xl mb-2 opacity-30">🖼️</div>
          <div class="text-sm font-bold text-ink-mute">자사몰 메인</div>
          <div class="text-xs text-ink-light mt-1">screen-mall.jpg</div>
          <div class="text-xs text-ink-light">(1200 × 1200px)</div>
        </div>
        <div class="aspect-square bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300 fade-up fade-up-delay-2">
          <div class="text-5xl mb-2 opacity-30">🖼️</div>
          <div class="text-sm font-bold text-ink-mute">정기구독 페이지</div>
          <div class="text-xs text-ink-light mt-1">subscription.jpg</div>
          <div class="text-xs text-ink-light">(1200 × 1200px)</div>
        </div>
        <div class="aspect-square bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300 fade-up fade-up-delay-3">
          <div class="text-5xl mb-2 opacity-30">🖼️</div>
          <div class="text-sm font-bold text-ink-mute">옴니채널 대시보드</div>
          <div class="text-xs text-ink-light mt-1">dashboard.jpg</div>
          <div class="text-xs text-ink-light">(1200 × 1200px)</div>
        </div>
        <div class="aspect-square bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300 fade-up fade-up-delay-1">
          <div class="text-5xl mb-2 opacity-30">🖼️</div>
          <div class="text-sm font-bold text-ink-mute">정기구독 워크플로우</div>
          <div class="text-xs text-ink-light mt-1">workflow.jpg</div>
          <div class="text-xs text-ink-light">(1200 × 1200px)</div>
        </div>
        <div class="aspect-square bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300 fade-up fade-up-delay-2">
          <div class="text-5xl mb-2 opacity-30">🖼️</div>
          <div class="text-sm font-bold text-ink-mute">ROAS 리포트</div>
          <div class="text-xs text-ink-light mt-1">roas-report.jpg</div>
          <div class="text-xs text-ink-light">(1200 × 1200px)</div>
        </div>
        <div class="aspect-square bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300 fade-up fade-up-delay-3">
          <div class="text-5xl mb-2 opacity-30">🖼️</div>
          <div class="text-sm font-bold text-ink-mute">재구매 분석</div>
          <div class="text-xs text-ink-light mt-1">repurchase.jpg</div>
          <div class="text-xs text-ink-light">(1200 × 1200px)</div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">⚡ BEFORE / AFTER</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">운영 전·후 변화</h2>
      </div>
      <div class="bg-white rounded-md overflow-hidden border border-gray-200 fade-up">
        <div class="grid grid-cols-3 bg-red text-white text-sm font-bold">
          <div class="p-4">📊 구분</div>
          <div class="p-4 border-l border-white/20">⏪ Before</div>
          <div class="p-4 border-l border-white/20">⏩ After</div>
        </div>
        {beforeAfter.map((row, i) => (
          <div class={`grid grid-cols-3 text-sm border-t border-gray-100 ${i % 2 === 1 ? "bg-bg-light" : ""}`}>
            <div class="p-4 font-bold text-ink-dark">{row.label}</div>
            <div class="p-4 text-ink-mute border-l border-gray-100">{row.before}</div>
            <div class="p-4 font-bold text-red border-l border-gray-100">{row.after}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-ink-black text-white py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">💬 INSIGHTS</div>
        <h2 class="text-2xl sm:text-3xl font-black text-white mb-10">클라이언트 인사이트</h2>
      </div>
      <div class="space-y-6">
        {insights.map((insight, i) => (
          <div class={`bg-white/5 border-l-[3px] border-red p-6 lg:p-8 rounded-r-md fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="text-2xl text-red mb-3">"</div>
            <p class="text-base lg:text-lg text-white/90 leading-relaxed mb-4 italic">{insight.quote}</p>
            <div class="text-xs text-red font-bold tracking-wide-en">— {caseData.brand} {insight.role}</div>
          </div>
        ))}
      </div>
      <p class="text-xs text-white/40 italic mt-8 text-center">
        * 본 인용구는 운영 과정에서 받은 피드백을 재구성한 것이며, NDA에 따라 일부 표현은 조정되었습니다.
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">🧩 SOLUTION APPLIED</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">적용 솔루션 요약</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-bg-card p-6 rounded-md card-hover fade-up fade-up-delay-1">
          <div class="text-3xl mb-3">🧩</div>
          <div class="font-en text-red text-xs font-bold tracking-wide-en mb-2">MODULES</div>
          <div class="text-base font-bold text-ink-dark mb-3">적용 모듈</div>
          <ul class="space-y-1.5">
            {caseData.modules.map(m => (
              <li class="text-sm text-ink-body flex gap-2"><span class="text-red">▸</span><span>{m}</span></li>
            ))}
          </ul>
        </div>
        <div class="bg-bg-card p-6 rounded-md card-hover fade-up fade-up-delay-2">
          <div class="text-3xl mb-3">🛒</div>
          <div class="font-en text-red text-xs font-bold tracking-wide-en mb-2">CHANNELS</div>
          <div class="text-base font-bold text-ink-dark mb-3">운영 채널</div>
          <ul class="space-y-1.5">
            {caseData.channels.map(c => (
              <li class="text-sm text-ink-body flex gap-2"><span class="text-red">▸</span><span>{c}</span></li>
            ))}
          </ul>
        </div>
        <div class="bg-bg-card p-6 rounded-md card-hover fade-up fade-up-delay-3">
          <div class="text-3xl mb-3">💎</div>
          <div class="font-en text-red text-xs font-bold tracking-wide-en mb-2">PRICING</div>
          <div class="text-base font-bold text-ink-dark mb-3">비용 구조</div>
          <div class="text-sm text-ink-body">{caseData.options}</div>
          <a href="/pricing/" class="text-xs text-red font-bold mt-3 inline-block link-slide">비용 구조 보기 →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up">
        <div class="section-eyebrow">🔗 RELATED CASES</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">다른 사례 보기</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {relatedCases.map((c, i) => (
          <a href={`/cases/${c.slug}/`} class={`bg-white rounded-md p-6 card-glow card-line-top block fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="flex items-center gap-3 mb-3">
              <div class="icon-circle-red">{c.emoji}</div>
              <div class="font-en text-red text-xs font-bold tracking-wide-en">{c.category}</div>
            </div>
            <div class="text-xl font-bold text-ink-dark mb-2">{c.brand}</div>
            <div class="text-sm text-ink-body mb-4">{c.tagline}</div>
            <div class="link-slide text-red text-sm">상세 보기<span class="arrow-icon">→</span></div>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center fade-up">
        <a href="/cases/" class="btn-secondary">전체 사례 보기<span class="arrow-icon">→</span></a>
      </div>
    </div>
  </section>

  <CtaBlock title="옴니채널 운영 효율화에 관심 있으신가요?" primary="유사 카테고리 문의" primaryHref="/contact/" />
</BaseLayout>
