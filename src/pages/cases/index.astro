---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBlock from "../../components/CtaBlock.astro";

const cases = [
  {
    slug: "bongpo",
    brand: "봉포머구리집",
    category: "F&B",
    tagline: "지역 노포의 전국 온라인 진입",
    period: "12개월 운영",
    modules: ["몰 개설·운영", "판매 촉진", "SEO"],
    summary: "오프라인 단일 매장에서 전국 단위 온라인 판매 채널로 확장. 자사몰 + 네이버 스마트스토어 + 쿠팡 3개 채널 동시 진입 후 블로그 시딩·맘카페·인플루언서 매체로 후기 자산을 누적했습니다.",
    results: [
      { label: "옴니채널 진입", value: "3개 채널" },
      { label: "월 매출", value: "8개월차 4.2배 성장" },
      { label: "누적 리뷰", value: "1,200건+" },
      { label: "네이버 키워드 1p", value: "12개 확보" },
    ],
  },
  {
    slug: "mrmilk",
    brand: "미스터밀크",
    category: "F&B",
    tagline: "정기구독 모델 + 옴니채널 효율화",
    period: "9개월 운영",
    modules: ["e커머스 마케팅", "몰 운영", "판매 촉진"],
    summary: "유제품 정기구독 모델 도입과 옴니채널 운영 효율화. 네이버·쿠팡·자사몰 통합 운영 체계 구축 후 가격 정합성·재고 동기화·정산 검증을 자동화. 정기구독 회원 확보로 재구매율 견인.",
    results: [
      { label: "정기구독 회원", value: "월 300명+ 신규" },
      { label: "재구매율", value: "62%" },
      { label: "운영 채널", value: "5개" },
      { label: "광고 ROAS", value: "평균 4.5" },
    ],
  },
  {
    slug: "serabloom",
    brand: "세라블룸",
    category: "건강기능식품",
    tagline: "광고법 컴플라이언스 + SEO 효율 확보",
    period: "10개월 운영",
    modules: ["SEO", "판매 촉진", "콘텐츠"],
    summary: "식약처 건강기능식품 광고 심의 기준에 맞춰 상세페이지·매체 소재를 일괄 재구성. 네이버 SEO 최적화와 Conversion 매체를 병행해 검색 노출 + 매출 동시 누적. 광고법 위반 위험 0건 유지.",
    results: [
      { label: "검색 1p 노출 키워드", value: "27개" },
      { label: "월 매출 성장", value: "전년 동월 대비 2.8배" },
      { label: "광고 심의 통과율", value: "100%" },
      { label: "월 후기 누적", value: "180건+" },
    ],
  },
  {
    slug: "richfarm",
    brand: "마켓리치팜",
    category: "건강기능식품",
    tagline: "프리미엄 라인 진입과 객단가 개선",
    period: "8개월 운영",
    modules: ["몰 운영", "콘텐츠", "AIO"],
    summary: "프리미엄 가격대 SKU의 채널별 페이지 재구성. 상세페이지·썸네일·옵션 패키지 재설계로 객단가 개선 + 리뷰 자산 누적. 생성형 AI 검색(Perplexity·ChatGPT) 대응을 위한 Schema Markup 적용.",
    results: [
      { label: "평균 객단가", value: "이전 대비 1.7배" },
      { label: "프리미엄 SKU 점유", value: "전체 매출의 34%" },
      { label: "AI 검색 노출", value: "월 1,400회+" },
      { label: "재구매율", value: "41%" },
    ],
  },
  {
    slug: "huonsn",
    brand: "휴온스엔",
    category: "헬스케어",
    tagline: "라이브커머스 + 브랜드 자산 통합",
    period: "11개월 운영",
    modules: ["브랜드 작업", "AIO", "판매 촉진"],
    summary: "헬스케어 카테고리 특성에 맞춘 라이브커머스 기획·실행·사후 클립 활용까지 일괄. 나무위키·브랜드 랜딩페이지 등 브랜드 자산 구축으로 신뢰도 제고. 네이버 쇼핑라이브 + Conversion 매체로 시청자 → 구매 동선 정량 측정.",
    results: [
      { label: "라이브 누적 시청", value: "82,000명" },
      { label: "라이브 1회 매출", value: "평균 2,800만원" },
      { label: "브랜드 검색량", value: "런칭 후 3.6배" },
      { label: "나무위키·랜딩 자산", value: "구축 완료" },
    ],
  },
];

const categories = ["전체", "F&B", "건강기능식품", "헬스케어"];
---

<BaseLayout
  title="사례 — 실제 운영 사례"
  description="F&B · 건강기능식품 · 헬스케어 — 카테고리별 검증된 운영 사례와 정량 결과."
  current="/cases/"
>
  <PageHero
    eyebrow="CASES"
    title="실제 운영 사례로 검증된 솔루션."
    sub="F&B · 건강기능식품 · 헬스케어 · 네이버 생태계 — 카테고리별 검증된 운영 경험을 결과 수치와 함께 공개합니다."
  />

  <!-- 카테고리 필터 -->
  <section class="py-10 border-b border-gray-100">
    <div class="container-page">
      <div class="flex flex-wrap gap-2">
        {categories.map((c, i) => (
          <button class={`px-4 py-2 rounded-full text-sm font-bold transition-colors ${i === 0 ? "bg-red text-white" : "bg-bg-light text-ink-body hover:bg-red/10"}`}>
            {c}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- 사례 카드 그리드 -->
  <section class="py-16 lg:py-20">
    <div class="container-page">
      <div class="space-y-8">
        {cases.map(c => (
          <article class="bg-white rounded-md overflow-hidden border border-gray-100 card-hover">
            <div class="grid lg:grid-cols-12 gap-0">
              <!-- 좌측 — 브랜드 정보 -->
              <div class="lg:col-span-4 bg-bg-light p-8 flex flex-col justify-between">
                <div>
                  <div class="font-en text-red text-xs font-bold tracking-wide-en mb-2">{c.category}</div>
                  <h3 class="text-2xl lg:text-3xl font-black text-ink-dark mb-3">{c.brand}</h3>
                  <div class="text-sm text-ink-mute mb-4">{c.tagline}</div>
                </div>
                <div>
                  <div class="text-xs text-ink-mute mb-2">운영 기간</div>
                  <div class="text-base font-bold text-red">{c.period}</div>
                  <div class="flex flex-wrap gap-1 mt-4">
                    {c.modules.map(m => (
                      <span class="text-xs bg-white text-ink-body px-2 py-1 rounded border border-gray-200">{m}</span>
                    ))}
                  </div>
                </div>
              </div>
              
              <!-- 우측 — 요약 + 결과 -->
              <div class="lg:col-span-8 p-8">
                <div class="text-xs font-bold text-red tracking-wide-en mb-2 font-en">APPROACH</div>
                <p class="text-sm text-ink-body leading-relaxed mb-6">{c.summary}</p>
                
                <div class="text-xs font-bold text-red tracking-wide-en mb-3 font-en">RESULTS</div>
                <div class="grid grid-cols-2 gap-4">
                  {c.results.map(r => (
                    <div class="border-l-[3px] border-red pl-3">
                      <div class="text-xs text-ink-mute mb-1">{r.label}</div>
                      <div class="text-base font-black text-ink-dark">{r.value}</div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
      
      <!-- 안내 박스 -->
      <div class="mt-12 bg-bg-light rounded-md p-6 text-center">
        <p class="text-sm text-ink-body italic">
          * 본 사례의 정량 수치는 운영 데이터 기반의 대표 수치이며, 클라이언트별 NDA에 따라 일부 수치는 가공·익명화되어 있습니다.
        </p>
      </div>
    </div>
  </section>

  <CtaBlock title="우리 브랜드와 유사한 사례를 보고 싶다면?" primary="유사 카테고리 문의" primaryHref="/contact/" />
</BaseLayout>
