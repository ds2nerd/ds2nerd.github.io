---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CtaBlock from "../../../components/CtaBlock.astro";

const mediaData = {
  name: "라이브커머스",
  emoji: "🎥",
  position: "CONVERSION",
  positionLabel: "전환 · 구매 직결",
  tagline: "기획부터 사후 클립 활용까지 라이브를 일괄 운영합니다.",
  description: "네이버 쇼핑라이브·쿠팡 라이브·카카오 쇼핑라이브를 중심으로 사전 기획, 라이브 실행, 사후 클립 활용까지 일괄 운영하는 매체입니다. 시청 → 구매 → 사후 후기 누적까지 매출과 자산이 동시에 형성되는 고효율 채널입니다.",
};

const kpis = [
  { label: "운영 플랫폼", value: "네이버·쿠팡·카카오", emoji: "📺" },
  { label: "운영 빈도", value: "월 2~3회 권장", emoji: "🔄" },
  { label: "주요 KPI", value: "시청자 · 매출 · ROAS", emoji: "📊" },
  { label: "효과 회수", value: "직후 ~ 7일", emoji: "⚡" },
];

const strengths = [
  {
    title: "실시간 전환력",
    desc: "라이브 진행 중 시청자와 양방향 소통하며 한정 특가·증정·사은품으로 즉시 구매 전환",
    emoji: "⚡",
  },
  {
    title: "사후 클립 자산화",
    desc: "라이브 종료 후 클립을 자사몰 상세페이지·인스타·유튜브 쇼츠로 재활용하여 장기 자산 형성",
    emoji: "💎",
  },
  {
    title: "검증된 매출 매체",
    desc: "1회 라이브 매출 평균 1,000~3,000만원 수준 (카테고리·SKU에 따라 변동)",
    emoji: "💰",
  },
  {
    title: "신뢰도 강화",
    desc: "MC가 직접 시연·설명하는 형식으로 광고형 매체 대비 신뢰도 우위, 헬스케어·건기식에 특히 강력",
    emoji: "✅",
  },
];

const process = [
  {
    phase: "Phase 1",
    title: "사전 기획 · 준비",
    period: "2~3주",
    emoji: "📋",
    items: [
      "라이브 콘셉트·일정·플랫폼 선정 (네이버 / 쿠팡 / 카카오)",
      "큐시트 작성 — 도입부·제품 시연·한정 특가·이벤트·종료",
      "MC 섭외 · 리허설 · 영상 송출 인프라 점검",
      "사전 인지 매체 캠페인 시작 (블로그 시딩·인플루언서 등)",
    ],
  },
  {
    phase: "Phase 2",
    title: "라이브 실행",
    period: "1~2시간",
    emoji: "🎥",
    items: [
      "라이브 진행 — 시연·시청자 소통·실시간 이벤트 운영",
      "한정 특가 쿠폰 발급 + 사은품 증정으로 즉시 전환 견인",
      "댓글·문의 실시간 응대 (CS 1차 응답 자동화)",
      "실시간 시청자·매출·문의 모니터링",
    ],
  },
  {
    phase: "Phase 3",
    title: "사후 클립 · 후기 운영",
    period: "1~4주",
    emoji: "📊",
    items: [
      "라이브 클립 편집 → 자사몰 상세페이지·SNS 재배포",
      "라이브 시청자 → 1회 구매 → 재구매 워크플로우 (이메일·SMS)",
      "신규 구매자 후기 누적 캠페인 (블로그 시딩 연계)",
      "월간 리포트 — 시청자·매출·재구매율·콘텐츠 자산",
    ],
  },
];
---

<BaseLayout
  title={`${mediaData.name} — ${mediaData.tagline}`}
  description="라이브커머스 매체 운영. 사전 기획·라이브 실행·사후 클립 활용 일괄 운영. 1회 평균 1,000~3,000만원 매출."
  current="/media/"
>
  <!-- 1. 히어로 -->
  <section class="bg-gradient-soft py-16 lg:py-20 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-3 h-full bg-conversion"></div>
    <div class="container-page max-w-5xl relative">
      <div class="flex items-center gap-2 text-sm mb-6 fade-up">
        <a href="/media/" class="text-ink-mute hover:text-red transition-colors">← 매체 라인업</a>
      </div>
      
      <div class="grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-7 fade-up">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-5xl">{mediaData.emoji}</div>
            <div class="inline-flex flex-col">
              <span class="font-en text-conversion text-xs font-bold tracking-wide-en">{mediaData.position}</span>
              <span class="text-xs text-ink-mute">{mediaData.positionLabel}</span>
            </div>
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-ink-black mb-4 leading-tight">
            {mediaData.name}
          </h1>
          <p class="text-lg lg:text-xl text-ink-body mb-6">{mediaData.tagline}</p>
          <p class="text-sm text-ink-mute leading-relaxed">{mediaData.description}</p>
        </div>
        
        <div class="lg:col-span-5 fade-up fade-up-delay-2">
          <div class="relative aspect-video rounded-md overflow-hidden">
            <img
              src="https://loremflickr.com/1600/900/livestream,broadcast,studio?lock=751"
              alt="라이브커머스 - 사전·라이브·사후 일괄"
              loading="lazy"
              class="w-full h-full object-cover"
            />
            <div class="absolute top-4 left-4 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2.5 py-1 rounded tracking-wide">MEDIA</div>
            <div class="absolute top-4 right-4 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2.5 py-1 rounded tracking-wide">CONVERSION</div>
            <div class="absolute bottom-4 left-4 right-4">
              <div class="bg-black/70 backdrop-blur-sm text-white px-3 py-2 rounded">
                <div class="text-base font-black">🎥 라이브커머스</div>
                <div class="text-xs opacity-90 mt-0.5">사전·라이브·사후 일괄</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. 매체 개요 -->
  <section class="py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up">
        <div class="section-eyebrow">📊 OVERVIEW</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">매체 개요</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {kpis.map((k, i) => (
          <div class={`bg-white border-2 border-conversion rounded-md p-6 text-center card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="text-3xl mb-3">{k.emoji}</div>
            <div class="text-xs font-bold text-ink-mute mb-2">{k.label}</div>
            <div class="text-base sm:text-lg font-black text-conversion">{k.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. 실제 집행 화면 -->
  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up text-center mb-10">
        <div class="section-eyebrow justify-center" style="display: inline-flex;">📸 EXECUTION</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-3 mt-3">실제 집행 화면</h2>
        <p class="text-sm text-ink-body max-w-2xl mx-auto">
          네이버 쇼핑라이브 진행 및 시청자·매출 데이터 화면입니다.
        </p>
      </div>
      
      <div class="max-w-4xl mx-auto mb-6 fade-up">
        <div class="relative aspect-video rounded-md overflow-hidden shadow-lg">
          <img
            src="https://loremflickr.com/1920/1080/live,streaming,shopping?lock=752"
            alt="라이브커머스 진행 화면 - 실제 집행 화면 예시"
            loading="lazy"
            class="w-full h-full object-cover"
          />
          <div class="absolute top-4 left-4 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2.5 py-1 rounded tracking-wide">LIVE</div>
          <div class="absolute top-4 right-4 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2.5 py-1 rounded tracking-wide">EXECUTION</div>
          <div class="absolute bottom-4 left-4 right-4">
            <div class="bg-black/70 backdrop-blur-sm text-white px-4 py-2.5 rounded">
              <div class="text-lg font-black">🎥 라이브커머스 진행 화면</div>
              <div class="text-sm opacity-90 mt-0.5">실제 집행 화면 예시</div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="max-w-4xl mx-auto grid sm:grid-cols-2 gap-4">
        <div class="fade-up fade-up-delay-1">
          <div class="relative aspect-video rounded-md overflow-hidden">
            <img
              src="https://loremflickr.com/1200/675/checklist,planning,studio?lock=753"
              alt="라이브 큐시트"
              loading="lazy"
              class="w-full h-full object-cover"
            />
            <div class="absolute top-3 left-3 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2 py-1 rounded">01</div>
            <div class="absolute bottom-3 left-3 bg-black/60 backdrop-blur-sm text-white text-xs font-medium px-2 py-1 rounded">📺 라이브 큐시트</div>
          </div>
        </div>
        <div class="fade-up fade-up-delay-2">
          <div class="relative aspect-video rounded-md overflow-hidden">
            <img
              src="https://loremflickr.com/1200/675/video,editing,clip?lock=754"
              alt="사후 클립 활용"
              loading="lazy"
              class="w-full h-full object-cover"
            />
            <div class="absolute top-3 left-3 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2 py-1 rounded">02</div>
            <div class="absolute bottom-3 left-3 bg-black/60 backdrop-blur-sm text-white text-xs font-medium px-2 py-1 rounded">✂️ 사후 클립 활용</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. 강점 -->
  <section class="py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">✨ STRENGTHS</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">왜 라이브커머스인가</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {strengths.map((s, i) => (
          <div class={`bg-white border-l-[3px] border-conversion p-6 rounded-r-md card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="flex items-center gap-3 mb-3">
              <div class="text-3xl">{s.emoji}</div>
              <div class="text-lg font-bold text-ink-dark">{s.title}</div>
            </div>
            <div class="text-sm text-ink-body leading-relaxed">{s.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. 운영 프로세스 -->
  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">⚡ PROCESS</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">운영 프로세스</h2>
      </div>
      <div class="space-y-8">
        {process.map((p, i) => (
          <div class={`bg-white border-l-[3px] border-conversion p-6 lg:p-8 rounded-r-md card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="flex items-center gap-4 mb-5">
              <div class="inline-flex items-center justify-center w-12 h-12 bg-conversion/10 text-conversion rounded-full text-xl">{p.emoji}</div>
              <div>
                <div class="font-en text-conversion text-xs font-bold tracking-wide-en mb-1">{p.phase}</div>
                <div class="flex items-baseline gap-3">
                  <h3 class="text-lg lg:text-xl font-bold text-ink-dark">{p.title}</h3>
                  <span class="text-xs font-bold text-conversion">⏱ {p.period}</span>
                </div>
              </div>
            </div>
            <ul class="space-y-2">
              {p.items.map(it => (
                <li class="text-sm text-ink-body flex gap-2">
                  <span class="text-conversion font-bold flex-shrink-0">▸</span>
                  <span>{it}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. CTA -->
  <CtaBlock 
    title="라이브커머스 운영을 함께해보고 싶으신가요?" 
    sub="단독 매체 집행도, 다른 매체와 조합한 풀스택 운영도 가능합니다. 견적·운영 옵션을 무료로 안내해드립니다."
    primary="견적 받기" 
    primaryHref="/contact/" 
    secondary="다른 매체 보기"
    secondaryHref="/media/"
  />
</BaseLayout>
