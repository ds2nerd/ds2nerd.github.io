---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CtaBlock from "../../../components/CtaBlock.astro";

const mediaData = {
  name: "나무위키 세팅",
  emoji: "📚",
  position: "ASSET",
  positionLabel: "자산 누적",
  tagline: "AI 검색 시대의 디지털 평판 기준점을 구축합니다.",
  description: "Google·Naver 등 전통 검색뿐 아니라 Perplexity·ChatGPT·Gemini 등 생성형 AI 검색의 답변 근거 데이터로 인용되는 나무위키 페이지를 구축·관리하는 매체입니다. 브랜드 신뢰도 형성과 디지털 평판의 기준점 역할을 합니다.",
};

const kpis = [
  { label: "활용 범위", value: "AI 검색 답변 근거", emoji: "🤖" },
  { label: "노출 검색엔진", value: "Google · Naver", emoji: "🔍" },
  { label: "주요 KPI", value: "검색 노출 · AI 인용", emoji: "📊" },
  { label: "효과 회수", value: "1~3개월", emoji: "📈" },
];

const strengths = [
  {
    title: "AI 검색 시대 대응",
    desc: "Perplexity · ChatGPT · Gemini · Claude 등 생성형 AI 검색의 답변 근거로 인용되어 브랜드 정확성 확보",
    emoji: "🤖",
  },
  {
    title: "디지털 평판 기준점",
    desc: "산발적으로 흩어진 브랜드 정보를 통합·정리하여 검색 시 일관된 메시지 전달",
    emoji: "💎",
  },
  {
    title: "검색 상위 노출",
    desc: "Google · Naver 통합검색 브랜드명 검색 시 상위 노출 가능 → 신뢰도 자동 형성",
    emoji: "🎯",
  },
  {
    title: "영구 자산",
    desc: "한 번 등재된 페이지는 운영 종료 후에도 잔존, 시간이 지날수록 자산 가치 증가",
    emoji: "♾️",
  },
];

const process = [
  {
    phase: "Phase 1",
    title: "사전 조사 · 자료 수집",
    period: "1~2주",
    emoji: "🔍",
    items: [
      "브랜드 등재 가능 여부 진단 (나무위키 등재 기준 확인)",
      "기존 공개 자료 수집 (보도자료 · 공식 사이트 · 인터뷰 등)",
      "객관적 출처 확보 — 등재 기준 충족을 위한 신뢰도 자료 우선 정리",
      "구조 설계 — 개요 · 연혁 · 제품 · 사회 활동 · 기타 등 항목",
    ],
  },
  {
    phase: "Phase 2",
    title: "페이지 작성 · 등재",
    period: "2~4주",
    emoji: "📝",
    items: [
      "나무위키 편집 가이드 준수 작성 (NPOV·검증 가능성 등)",
      "출처 표기 · 인용 형식 표준화",
      "주요 항목 작성 → 단계적 등재 (한 번에 대량 등재 시 토론 회부 위험)",
      "삭제·반달리즘 모니터링 (등재 초기 1~2주 집중)",
    ],
  },
  {
    phase: "Phase 3",
    title: "유지·확장 운영",
    period: "지속",
    emoji: "📊",
    items: [
      "신규 이벤트·제품·언론 보도 발생 시 페이지 업데이트",
      "Google · Naver 검색 노출 모니터링 (브랜드명 검색 결과)",
      "AI 검색 답변 인용 추적 (Perplexity · ChatGPT · Gemini)",
      "월간 리포트 — 검색 노출·AI 인용·페이지뷰",
    ],
  },
];
---

<BaseLayout
  title={`${mediaData.name} — ${mediaData.tagline}`}
  description="나무위키 세팅 운영. AI 검색 시대의 브랜드 평판 기준점 구축. Perplexity·ChatGPT·Gemini 답변 근거로 인용."
  current="/media/"
>
  <!-- 1. 히어로 -->
  <section class="bg-gradient-soft py-16 lg:py-20 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-3 h-full bg-asset"></div>
    <div class="container-page max-w-5xl relative">
      <div class="flex items-center gap-2 text-sm mb-6 fade-up">
        <a href="/media/" class="text-ink-mute hover:text-red transition-colors">← 매체 라인업</a>
      </div>
      
      <div class="grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-7 fade-up">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-5xl">{mediaData.emoji}</div>
            <div class="inline-flex flex-col">
              <span class="font-en text-asset text-xs font-bold tracking-wide-en">{mediaData.position}</span>
              <span class="text-xs text-ink-mute">{mediaData.positionLabel}</span>
            </div>
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-ink-black mb-4 leading-tight">
            {mediaData.name}
          </h1>
          <p class="text-lg lg:text-xl text-ink-body mb-6">{mediaData.tagline}</p>
          <p class="text-sm text-ink-mute leading-relaxed">{mediaData.description}</p>
        </div>
        
        <div class="lg:col-span-5 fade-up fade-up-delay-2">
          <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
            <div class="text-5xl mb-2 opacity-30">🖼️</div>
            <div class="text-sm font-bold text-ink-mute">매체 메인 이미지</div>
            <div class="text-xs text-ink-light mt-1">hero.jpg (1600 × 900px)</div>
            <div class="text-xs text-ink-light">/public/media/namuwiki/</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. 매체 개요 -->
  <section class="py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up">
        <div class="section-eyebrow">📊 OVERVIEW</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">매체 개요</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {kpis.map((k, i) => (
          <div class={`bg-white border-2 border-asset rounded-md p-6 text-center card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="text-3xl mb-3">{k.emoji}</div>
            <div class="text-xs font-bold text-ink-mute mb-2">{k.label}</div>
            <div class="text-base sm:text-lg font-black text-asset">{k.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 실제 집행 화면 -->
  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up text-center mb-10">
        <div class="section-eyebrow justify-center" style="display: inline-flex;">📸 EXECUTION</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-3 mt-3">실제 등재 사례</h2>
        <p class="text-sm text-ink-body max-w-2xl mx-auto">
          나무위키 페이지 + Google · AI 검색 답변 인용 화면입니다.
        </p>
      </div>
      
      <div class="max-w-4xl mx-auto mb-6 fade-up">
        <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
          <div class="text-7xl mb-3 opacity-30">🖼️</div>
          <div class="text-base font-bold text-ink-mute">나무위키 페이지 화면</div>
          <div class="text-xs text-ink-light mt-2">execution-main.jpg (1920 × 1080px)</div>
          <div class="text-xs text-ink-light">/public/media/namuwiki/</div>
          <div class="text-xs text-ink-light mt-2 italic">실제 등재된 나무위키 페이지 캡처</div>
        </div>
      </div>
      
      <div class="max-w-4xl mx-auto grid sm:grid-cols-2 gap-4">
        <div class="fade-up fade-up-delay-1">
          <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
            <div class="text-5xl mb-2 opacity-30">🖼️</div>
            <div class="text-sm font-bold text-ink-mute">Google 검색 결과</div>
            <div class="text-xs text-ink-light mt-1">execution-google.jpg</div>
            <div class="text-xs text-ink-light">(1200 × 675px)</div>
          </div>
        </div>
        <div class="fade-up fade-up-delay-2">
          <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
            <div class="text-5xl mb-2 opacity-30">🖼️</div>
            <div class="text-sm font-bold text-ink-mute">Perplexity·ChatGPT 답변</div>
            <div class="text-xs text-ink-light mt-1">execution-ai.jpg</div>
            <div class="text-xs text-ink-light">(1200 × 675px)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. 강점 -->
  <section class="py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">✨ STRENGTHS</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">왜 나무위키 세팅인가</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {strengths.map((s, i) => (
          <div class={`bg-white border-l-[3px] border-asset p-6 rounded-r-md card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="flex items-center gap-3 mb-3">
              <div class="text-3xl">{s.emoji}</div>
              <div class="text-lg font-bold text-ink-dark">{s.title}</div>
            </div>
            <div class="text-sm text-ink-body leading-relaxed">{s.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. 운영 프로세스 -->
  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">⚡ PROCESS</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">운영 프로세스</h2>
      </div>
      <div class="space-y-8">
        {process.map((p, i) => (
          <div class={`bg-white border-l-[3px] border-asset p-6 lg:p-8 rounded-r-md card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="flex items-center gap-4 mb-5">
              <div class="inline-flex items-center justify-center w-12 h-12 bg-asset/10 text-asset rounded-full text-xl">{p.emoji}</div>
              <div>
                <div class="font-en text-asset text-xs font-bold tracking-wide-en mb-1">{p.phase}</div>
                <div class="flex items-baseline gap-3">
                  <h3 class="text-lg lg:text-xl font-bold text-ink-dark">{p.title}</h3>
                  <span class="text-xs font-bold text-asset">⏱ {p.period}</span>
                </div>
              </div>
            </div>
            <ul class="space-y-2">
              {p.items.map(it => (
                <li class="text-sm text-ink-body flex gap-2">
                  <span class="text-asset font-bold flex-shrink-0">▸</span>
                  <span>{it}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <CtaBlock 
    title="나무위키 세팅으로 AI 검색 시대를 준비하세요." 
    sub="Perplexity·ChatGPT·Gemini 답변 근거로 인용. 견적·운영 옵션을 무료로 안내해드립니다."
    primary="견적 받기" 
    primaryHref="/contact/" 
    secondary="다른 매체 보기"
    secondaryHref="/media/"
  />
</BaseLayout>
