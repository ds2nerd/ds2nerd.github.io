---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CtaBlock from "../../../components/CtaBlock.astro";

const mediaData = {
  name: "인플루언서 체험단",
  emoji: "🌟",
  position: "CONVERSION",
  positionLabel: "전환 · 구매 직결",
  tagline: "실체험 후기로 도달과 신뢰를 동시에 확보합니다.",
  description: "인스타·유튜브·틱톡·블로그 등 채널별 인플루언서의 실체험 후기 콘텐츠를 통해 도달과 신뢰를 동시에 확보하는 매체입니다. 인플루언서별 매출 정량 비교가 가능하도록 전용 쿠폰 코드·UTM을 적용해 효율 인플루언서를 식별합니다.",
};

const kpis = [
  { label: "운영 채널", value: "인스타·유튜브·틱톡·블로그", emoji: "📡" },
  { label: "측정 방식", value: "쿠폰코드 · UTM", emoji: "🎯" },
  { label: "주요 KPI", value: "매체별 매출 비교", emoji: "📊" },
  { label: "효과 회수", value: "1~3주", emoji: "⚡" },
];

const strengths = [
  {
    title: "실체험 신뢰도",
    desc: "팔로워와 정서적 유대를 가진 인플루언서의 직접 사용 후기로 광고 거부감 최소화",
    emoji: "✅",
  },
  {
    title: "정량 매출 추적",
    desc: "인플루언서별 전용 쿠폰 코드·UTM 적용 → 누가 얼마의 매출을 만들었는지 정량 비교",
    emoji: "📊",
  },
  {
    title: "다채널 동시 도달",
    desc: "인스타 + 유튜브 + 틱톡 + 블로그 동시 운영으로 채널별 타겟층에 모두 도달",
    emoji: "🌐",
  },
  {
    title: "콘텐츠 2차 활용",
    desc: "인플루언서 제작 콘텐츠 → 자사몰 상세페이지·SNS·광고 소재로 재활용 가능 (저작권 협의)",
    emoji: "💎",
  },
];

const process = [
  {
    phase: "Phase 1",
    title: "인플루언서 매칭 · 협의",
    period: "1~2주",
    emoji: "🔍",
    items: [
      "카테고리·타겟층·팔로워 수 기반 인플루언서 리스트업",
      "메가·매크로·마이크로·나노 인플루언서 믹스 전략 수립",
      "협찬 조건 협의 (제품 협찬·고정 비용·인센티브 매출 분배)",
      "콘텐츠 가이드 작성 — 필수 키워드·금지 표현·노출 각도",
    ],
  },
  {
    phase: "Phase 2",
    title: "제품 발송 · 콘텐츠 제작",
    period: "2~3주",
    emoji: "📦",
    items: [
      "제품 발송 + 인플루언서별 전용 쿠폰 코드 발급",
      "콘텐츠 사전 검수 (광고법·브랜드 메시지 일관성)",
      "인스타 피드·릴스·유튜브 영상·틱톡·블로그 발행",
      "발행 직후 댓글·반응 모니터링",
    ],
  },
  {
    phase: "Phase 3",
    title: "성과 측정 · 정산",
    period: "1~4주",
    emoji: "📊",
    items: [
      "인플루언서별 쿠폰 코드·UTM 매출 정량 측정",
      "도달·저장·공유·DM 문의 등 정성 지표 종합 분석",
      "고효율 인플루언서 → 차기 캠페인 우선 매칭 풀로 관리",
      "월간 리포트 — 인플루언서별 매출·ROAS·후기 자산",
    ],
  },
];
---

<BaseLayout
  title={`${mediaData.name} — ${mediaData.tagline}`}
  description="인플루언서 체험단 매체 운영. 인스타·유튜브·틱톡·블로그 다채널 동시 도달 + 매체별 매출 정량 비교."
  current="/media/"
>
  <!-- 1. 히어로 -->
  <section class="bg-gradient-soft py-16 lg:py-20 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-3 h-full bg-conversion"></div>
    <div class="container-page max-w-5xl relative">
      <div class="flex items-center gap-2 text-sm mb-6 fade-up">
        <a href="/media/" class="text-ink-mute hover:text-red transition-colors">← 매체 라인업</a>
      </div>
      
      <div class="grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-7 fade-up">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-5xl">{mediaData.emoji}</div>
            <div class="inline-flex flex-col">
              <span class="font-en text-conversion text-xs font-bold tracking-wide-en">{mediaData.position}</span>
              <span class="text-xs text-ink-mute">{mediaData.positionLabel}</span>
            </div>
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-ink-black mb-4 leading-tight">
            {mediaData.name}
          </h1>
          <p class="text-lg lg:text-xl text-ink-body mb-6">{mediaData.tagline}</p>
          <p class="text-sm text-ink-mute leading-relaxed">{mediaData.description}</p>
        </div>
        
        <div class="lg:col-span-5 fade-up fade-up-delay-2">
          <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
            <div class="text-5xl mb-2 opacity-30">🖼️</div>
            <div class="text-sm font-bold text-ink-mute">매체 메인 이미지</div>
            <div class="text-xs text-ink-light mt-1">hero.jpg (1600 × 900px)</div>
            <div class="text-xs text-ink-light">/public/media/influencer/</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. 매체 개요 -->
  <section class="py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up">
        <div class="section-eyebrow">📊 OVERVIEW</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">매체 개요</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {kpis.map((k, i) => (
          <div class={`bg-white border-2 border-conversion rounded-md p-6 text-center card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="text-3xl mb-3">{k.emoji}</div>
            <div class="text-xs font-bold text-ink-mute mb-2">{k.label}</div>
            <div class="text-base sm:text-lg font-black text-conversion">{k.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 실제 집행 화면 -->
  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up text-center mb-10">
        <div class="section-eyebrow justify-center" style="display: inline-flex;">📸 EXECUTION</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-3 mt-3">실제 집행 화면</h2>
        <p class="text-sm text-ink-body max-w-2xl mx-auto">
          인플루언서별 콘텐츠 노출 및 매출 추적 화면입니다.
        </p>
      </div>
      
      <div class="max-w-4xl mx-auto mb-6 fade-up">
        <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
          <div class="text-7xl mb-3 opacity-30">🖼️</div>
          <div class="text-base font-bold text-ink-mute">인플루언서 콘텐츠 모음</div>
          <div class="text-xs text-ink-light mt-2">execution-main.jpg (1920 × 1080px)</div>
          <div class="text-xs text-ink-light">/public/media/influencer/</div>
          <div class="text-xs text-ink-light mt-2 italic">실제 인플루언서 콘텐츠 화면 캡처</div>
        </div>
      </div>
      
      <div class="max-w-4xl mx-auto grid sm:grid-cols-2 gap-4">
        <div class="fade-up fade-up-delay-1">
          <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
            <div class="text-5xl mb-2 opacity-30">🖼️</div>
            <div class="text-sm font-bold text-ink-mute">인플루언서 콘텐츠 샘플</div>
            <div class="text-xs text-ink-light mt-1">execution-content.jpg</div>
            <div class="text-xs text-ink-light">(1200 × 675px)</div>
          </div>
        </div>
        <div class="fade-up fade-up-delay-2">
          <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
            <div class="text-5xl mb-2 opacity-30">🖼️</div>
            <div class="text-sm font-bold text-ink-mute">매출 비교 리포트</div>
            <div class="text-xs text-ink-light mt-1">execution-report.jpg</div>
            <div class="text-xs text-ink-light">(1200 × 675px)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. 강점 -->
  <section class="py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">✨ STRENGTHS</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">왜 인플루언서 체험단인가</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {strengths.map((s, i) => (
          <div class={`bg-white border-l-[3px] border-conversion p-6 rounded-r-md card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="flex items-center gap-3 mb-3">
              <div class="text-3xl">{s.emoji}</div>
              <div class="text-lg font-bold text-ink-dark">{s.title}</div>
            </div>
            <div class="text-sm text-ink-body leading-relaxed">{s.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. 운영 프로세스 -->
  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">⚡ PROCESS</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">운영 프로세스</h2>
      </div>
      <div class="space-y-8">
        {process.map((p, i) => (
          <div class={`bg-white border-l-[3px] border-conversion p-6 lg:p-8 rounded-r-md card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="flex items-center gap-4 mb-5">
              <div class="inline-flex items-center justify-center w-12 h-12 bg-conversion/10 text-conversion rounded-full text-xl">{p.emoji}</div>
              <div>
                <div class="font-en text-conversion text-xs font-bold tracking-wide-en mb-1">{p.phase}</div>
                <div class="flex items-baseline gap-3">
                  <h3 class="text-lg lg:text-xl font-bold text-ink-dark">{p.title}</h3>
                  <span class="text-xs font-bold text-conversion">⏱ {p.period}</span>
                </div>
              </div>
            </div>
            <ul class="space-y-2">
              {p.items.map(it => (
                <li class="text-sm text-ink-body flex gap-2">
                  <span class="text-conversion font-bold flex-shrink-0">▸</span>
                  <span>{it}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <CtaBlock 
    title="인플루언서 체험단으로 다채널 도달을 만들어보세요." 
    sub="인스타·유튜브·틱톡·블로그 다채널 동시 운영. 견적·운영 옵션을 무료로 안내해드립니다."
    primary="견적 받기" 
    primaryHref="/contact/" 
    secondary="다른 매체 보기"
    secondaryHref="/media/"
  />
</BaseLayout>
