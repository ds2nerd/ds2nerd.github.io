---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CtaBlock from "../../../components/CtaBlock.astro";

const mediaData = {
  name: "푸망 프리미엄 심리테스트 PKG",
  emoji: "🎮",
  position: "AWARENESS",
  positionLabel: "대중 인지",
  tagline: "브랜드 메시지를 '놀이'로 전환하는 MZ 참여형 매체.",
  description: "MZ세대 참여형 콘텐츠로 브랜드 메시지를 '놀이'로 전환하여 인지를 확산하는 매체입니다. MAU 362만·월간 PV 200만·누적 제작 550건+·협업 고객사 260곳+ 의 검증된 플랫폼으로, 카테고리 인지를 한 단계 점프시키는 데 강력합니다.",
};

const kpis = [
  { label: "MAU", value: "362만", emoji: "👥" },
  { label: "월간 PV", value: "200만+", emoji: "👁" },
  { label: "주요 KPI", value: "플레이수 · 결과 CTR", emoji: "📊" },
  { label: "효과 회수", value: "2~8주", emoji: "📈" },
];

const strengths = [
  {
    title: "MZ세대 참여형",
    desc: "단순 광고 노출이 아닌 직접 '놀이'로 참여 → 자발적 공유 + 브랜드 메시지 자연 학습",
    emoji: "🎯",
  },
  {
    title: "검증된 플랫폼",
    desc: "MAU 362만 · 누적 제작 550건+ · 협업 고객사 260곳+ 의 실증된 매체 효과",
    emoji: "✅",
  },
  {
    title: "바이럴 확산",
    desc: "심리테스트 결과 화면 SNS 공유 유도 → 광고비 외 자연 확산 도달 발생",
    emoji: "🚀",
  },
  {
    title: "브랜드 인지 점프",
    desc: "카테고리 단순 인지를 넘어 브랜드 메시지 + 페르소나까지 동시 전달",
    emoji: "💎",
  },
];

const process = [
  {
    phase: "Phase 1",
    title: "콘셉트 기획",
    period: "1~2주",
    emoji: "📋",
    items: [
      "브랜드 메시지·페르소나·핵심 가치 정리",
      "심리테스트 콘셉트 큐레이션 (10~15문항 · 4~8결과)",
      "테스트 결과별 브랜드 메시지 자연 삽입 설계",
      "공유 동기 강화 — 결과 화면 SNS 공유 디자인",
    ],
  },
  {
    phase: "Phase 2",
    title: "제작 · 송출",
    period: "2~3주",
    emoji: "🎨",
    items: [
      "푸망 플랫폼에 심리테스트 제작 + 게시",
      "결과 화면 디자인 + 브랜드 페이지 연결 (UTM 적용)",
      "송출 첫 1주 활동 집중 — 푸망 메인 노출",
      "초기 플레이수·공유율·결과별 CTR 모니터링",
    ],
  },
  {
    phase: "Phase 3",
    title: "확산 · 자산화",
    period: "2~8주",
    emoji: "📊",
    items: [
      "고공유 결과 화면 추가 광고 집행 (SNS 페이드 매체)",
      "결과 화면 → 자사 SNS·블로그 콘텐츠 재가공",
      "플레이어 데이터 분석 → 타겟 인사이트 확보",
      "월간 리포트 — 누적 플레이수·공유율·자사몰 유입",
    ],
  },
];
---

<BaseLayout
  title={`${mediaData.name} — ${mediaData.tagline}`}
  description="푸망 프리미엄 심리테스트 PKG 운영. MAU 362만 MZ세대 참여형 매체로 브랜드 인지 확산."
  current="/media/"
>
  <!-- 1. 히어로 -->
  <section class="bg-gradient-soft py-16 lg:py-20 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-3 h-full bg-awareness"></div>
    <div class="container-page max-w-5xl relative">
      <div class="flex items-center gap-2 text-sm mb-6 fade-up">
        <a href="/media/" class="text-ink-mute hover:text-red transition-colors">← 매체 라인업</a>
      </div>
      
      <div class="grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-7 fade-up">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-5xl">{mediaData.emoji}</div>
            <div class="inline-flex flex-col">
              <span class="font-en text-awareness text-xs font-bold tracking-wide-en">{mediaData.position}</span>
              <span class="text-xs text-ink-mute">{mediaData.positionLabel}</span>
            </div>
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-ink-black mb-4 leading-tight">
            {mediaData.name}
          </h1>
          <p class="text-lg lg:text-xl text-ink-body mb-6">{mediaData.tagline}</p>
          <p class="text-sm text-ink-mute leading-relaxed">{mediaData.description}</p>
        </div>
        
        <div class="lg:col-span-5 fade-up fade-up-delay-2">
          <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
            <div class="text-5xl mb-2 opacity-30">🖼️</div>
            <div class="text-sm font-bold text-ink-mute">매체 메인 이미지</div>
            <div class="text-xs text-ink-light mt-1">hero.jpg (1600 × 900px)</div>
            <div class="text-xs text-ink-light">/public/media/pumang/</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. 매체 개요 -->
  <section class="py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up">
        <div class="section-eyebrow">📊 OVERVIEW</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">매체 개요</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {kpis.map((k, i) => (
          <div class={`bg-white border-2 border-awareness rounded-md p-6 text-center card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="text-3xl mb-3">{k.emoji}</div>
            <div class="text-xs font-bold text-ink-mute mb-2">{k.label}</div>
            <div class="text-base sm:text-lg font-black text-awareness">{k.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 실제 집행 화면 -->
  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up text-center mb-10">
        <div class="section-eyebrow justify-center" style="display: inline-flex;">📸 EXECUTION</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-3 mt-3">실제 집행 화면</h2>
        <p class="text-sm text-ink-body max-w-2xl mx-auto">
          푸망 플랫폼 심리테스트 진행 화면 및 결과 화면입니다.
        </p>
      </div>
      
      <div class="max-w-4xl mx-auto mb-6 fade-up">
        <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
          <div class="text-7xl mb-3 opacity-30">🖼️</div>
          <div class="text-base font-bold text-ink-mute">푸망 심리테스트 진행 화면</div>
          <div class="text-xs text-ink-light mt-2">execution-main.jpg (1920 × 1080px)</div>
          <div class="text-xs text-ink-light">/public/media/pumang/</div>
          <div class="text-xs text-ink-light mt-2 italic">실제 푸망 플랫폼 테스트 화면 캡처</div>
        </div>
      </div>
      
      <div class="max-w-4xl mx-auto grid sm:grid-cols-2 gap-4">
        <div class="fade-up fade-up-delay-1">
          <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
            <div class="text-5xl mb-2 opacity-30">🖼️</div>
            <div class="text-sm font-bold text-ink-mute">결과 화면 + 공유</div>
            <div class="text-xs text-ink-light mt-1">execution-result.jpg</div>
            <div class="text-xs text-ink-light">(1200 × 675px)</div>
          </div>
        </div>
        <div class="fade-up fade-up-delay-2">
          <div class="aspect-video bg-gray-100 rounded-md flex flex-col items-center justify-center border-2 border-dashed border-gray-300">
            <div class="text-5xl mb-2 opacity-30">🖼️</div>
            <div class="text-sm font-bold text-ink-mute">플레이수·공유율 리포트</div>
            <div class="text-xs text-ink-light mt-1">execution-report.jpg</div>
            <div class="text-xs text-ink-light">(1200 × 675px)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. 강점 -->
  <section class="py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">✨ STRENGTHS</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">왜 푸망 심리테스트인가</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {strengths.map((s, i) => (
          <div class={`bg-white border-l-[3px] border-awareness p-6 rounded-r-md card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="flex items-center gap-3 mb-3">
              <div class="text-3xl">{s.emoji}</div>
              <div class="text-lg font-bold text-ink-dark">{s.title}</div>
            </div>
            <div class="text-sm text-ink-body leading-relaxed">{s.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. 운영 프로세스 -->
  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">⚡ PROCESS</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">운영 프로세스</h2>
      </div>
      <div class="space-y-8">
        {process.map((p, i) => (
          <div class={`bg-white border-l-[3px] border-awareness p-6 lg:p-8 rounded-r-md card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="flex items-center gap-4 mb-5">
              <div class="inline-flex items-center justify-center w-12 h-12 bg-awareness/10 text-awareness rounded-full text-xl">{p.emoji}</div>
              <div>
                <div class="font-en text-awareness text-xs font-bold tracking-wide-en mb-1">{p.phase}</div>
                <div class="flex items-baseline gap-3">
                  <h3 class="text-lg lg:text-xl font-bold text-ink-dark">{p.title}</h3>
                  <span class="text-xs font-bold text-awareness">⏱ {p.period}</span>
                </div>
              </div>
            </div>
            <ul class="space-y-2">
              {p.items.map(it => (
                <li class="text-sm text-ink-body flex gap-2">
                  <span class="text-awareness font-bold flex-shrink-0">▸</span>
                  <span>{it}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <CtaBlock 
    title="푸망 심리테스트로 MZ세대 인지를 점프시켜보세요." 
    sub="MAU 362만 검증된 참여형 매체. 견적·운영 옵션을 무료로 안내해드립니다."
    primary="견적 받기" 
    primaryHref="/contact/" 
    secondary="다른 매체 보기"
    secondaryHref="/media/"
  />
</BaseLayout>
