---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CtaBlock from "../../../components/CtaBlock.astro";

const mediaData = {
  name: "브랜드 랜딩페이지",
  emoji: "🌐",
  position: "ASSET",
  positionLabel: "자산 누적",
  tagline: "매체 트래픽의 도착지이자 영구 자산이 되는 페이지.",
  description: "워드프레스 기반 반응형 웹으로 구축되며, 매체 트래픽이 자연스럽게 머무르는 도착지(landing) 역할을 수행합니다. SEO·AIO(Schema Markup) 대응으로 시간이 지날수록 검색 자산과 브랜드 자산이 동시에 누적되는 매체입니다.",
};

const kpis = [
  { label: "구축 기반", value: "워드프레스 반응형", emoji: "💻" },
  { label: "SEO·AIO", value: "Schema Markup", emoji: "🔍" },
  { label: "주요 KPI", value: "전환율 · 회원가입", emoji: "📊" },
  { label: "효과 회수", value: "지속 누적", emoji: "💎" },
];

const strengths = [
  {
    title: "매체 도착지 역할",
    desc: "외부 광고·매체 트래픽이 이탈 없이 머무르는 도착지로 작동, 전환·DB 수집의 핵심 거점",
    emoji: "🎯",
  },
  {
    title: "검색 자산 누적",
    desc: "SEO 최적화 + Schema Markup으로 Google·Naver·Perplexity·ChatGPT 검색 답변에 인용",
    emoji: "🔍",
  },
  {
    title: "브랜드 일관성",
    desc: "자사몰·SNS·매체에 흩어진 브랜드 메시지의 중심점 역할 → 통일된 브랜드 인상 구축",
    emoji: "✨",
  },
  {
    title: "장기 자산화",
    desc: "한 번 구축하면 운영 중단 후에도 자산 잔존, 시간이 지날수록 검색 유입 증가",
    emoji: "💎",
  },
];

const process = [
  {
    phase: "Phase 1",
    title: "기획 · 디자인",
    period: "2~3주",
    emoji: "📋",
    items: [
      "브랜드 메시지·페르소나·핵심 키워드 정리",
      "사이트맵 설계 (메인·브랜드 스토리·제품·후기·문의)",
      "디자인 콘셉트 → 와이어프레임 → 비주얼 시안 단계 진행",
      "모바일 우선 반응형 설계 (모바일 70%·태블릿·데스크탑)",
    ],
  },
  {
    phase: "Phase 2",
    title: "개발 · SEO·AIO 적용",
    period: "3~4주",
    emoji: "💻",
    items: [
      "워드프레스 커스텀 테마 개발 (속도·SEO 최적화)",
      "Schema.org 마크업 적용 (Organization · Product · FAQ · Review)",
      "구조화 데이터 검증 → Google·Bing 색인 정상 확인",
      "GA4·서치콘솔·네이버 서치어드바이저 연동",
    ],
  },
  {
    phase: "Phase 3",
    title: "운영 · 콘텐츠 누적",
    period: "지속",
    emoji: "📊",
    items: [
      "월간 콘텐츠 업데이트 (블로그·신제품·이벤트 페이지)",
      "검색 유입 키워드 모니터링 → 콘텐츠 추가·최적화",
      "AI 검색 결과 인용 추적 (Perplexity·ChatGPT)",
      "월간 리포트 — 검색 유입·전환율·DB 수집·페이지뷰",
    ],
  },
];
---

<BaseLayout
  title={`${mediaData.name} — ${mediaData.tagline}`}
  description="브랜드 랜딩페이지 구축·운영. 워드프레스 반응형 + SEO·AIO 대응으로 영구 검색 자산 누적."
  current="/media/"
>
  <!-- 1. 히어로 -->
  <section class="bg-gradient-soft py-16 lg:py-20 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-3 h-full bg-asset"></div>
    <div class="container-page max-w-5xl relative">
      <div class="flex items-center gap-2 text-sm mb-6 fade-up">
        <a href="/media/" class="text-ink-mute hover:text-red transition-colors">← 매체 라인업</a>
      </div>
      
      <div class="grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-7 fade-up">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-5xl">{mediaData.emoji}</div>
            <div class="inline-flex flex-col">
              <span class="font-en text-asset text-xs font-bold tracking-wide-en">{mediaData.position}</span>
              <span class="text-xs text-ink-mute">{mediaData.positionLabel}</span>
            </div>
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-ink-black mb-4 leading-tight">
            {mediaData.name}
          </h1>
          <p class="text-lg lg:text-xl text-ink-body mb-6">{mediaData.tagline}</p>
          <p class="text-sm text-ink-mute leading-relaxed">{mediaData.description}</p>
        </div>
        
        <div class="lg:col-span-5 fade-up fade-up-delay-2">
          <div class="relative aspect-video rounded-md overflow-hidden">
            <img
              src="https://loremflickr.com/1600/900/webdesign,website,laptop?lock=761"
              alt="브랜드 랜딩페이지 - 검색·브랜드 자산 누적"
              loading="lazy"
              class="w-full h-full object-cover"
            />
            <div class="absolute top-4 left-4 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2.5 py-1 rounded tracking-wide">MEDIA</div>
            <div class="absolute top-4 right-4 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2.5 py-1 rounded tracking-wide">ASSET</div>
            <div class="absolute bottom-4 left-4 right-4">
              <div class="bg-black/70 backdrop-blur-sm text-white px-3 py-2 rounded">
                <div class="text-base font-black">🌐 브랜드 랜딩페이지</div>
                <div class="text-xs opacity-90 mt-0.5">검색·브랜드 자산 누적</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. 매체 개요 -->
  <section class="py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up">
        <div class="section-eyebrow">📊 OVERVIEW</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">매체 개요</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {kpis.map((k, i) => (
          <div class={`bg-white border-2 border-asset rounded-md p-6 text-center card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="text-3xl mb-3">{k.emoji}</div>
            <div class="text-xs font-bold text-ink-mute mb-2">{k.label}</div>
            <div class="text-base sm:text-lg font-black text-asset">{k.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 실제 집행 화면 -->
  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page">
      <div class="fade-up text-center mb-10">
        <div class="section-eyebrow justify-center" style="display: inline-flex;">📸 EXECUTION</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-3 mt-3">실제 구축 사례</h2>
        <p class="text-sm text-ink-body max-w-2xl mx-auto">
          워드프레스 기반 반응형 랜딩페이지 구축 사례입니다.
        </p>
      </div>
      
      <div class="max-w-4xl mx-auto mb-6 fade-up">
        <div class="relative aspect-video rounded-md overflow-hidden shadow-lg">
          <img
            src="https://loremflickr.com/1920/1080/webdesign,landing,modern?lock=762"
            alt="랜딩페이지 메인 화면 - 실제 집행 화면 예시"
            loading="lazy"
            class="w-full h-full object-cover"
          />
          <div class="absolute top-4 left-4 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2.5 py-1 rounded tracking-wide">LIVE</div>
          <div class="absolute top-4 right-4 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2.5 py-1 rounded tracking-wide">EXECUTION</div>
          <div class="absolute bottom-4 left-4 right-4">
            <div class="bg-black/70 backdrop-blur-sm text-white px-4 py-2.5 rounded">
              <div class="text-lg font-black">🌐 랜딩페이지 메인 화면</div>
              <div class="text-sm opacity-90 mt-0.5">실제 집행 화면 예시</div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="max-w-4xl mx-auto grid sm:grid-cols-2 gap-4">
        <div class="fade-up fade-up-delay-1">
          <div class="relative aspect-video rounded-md overflow-hidden">
            <img
              src="https://loremflickr.com/1200/675/smartphone,responsive,mobile?lock=763"
              alt="모바일 화면"
              loading="lazy"
              class="w-full h-full object-cover"
            />
            <div class="absolute top-3 left-3 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2 py-1 rounded">01</div>
            <div class="absolute bottom-3 left-3 bg-black/60 backdrop-blur-sm text-white text-xs font-medium px-2 py-1 rounded">📱 모바일 화면</div>
          </div>
        </div>
        <div class="fade-up fade-up-delay-2">
          <div class="relative aspect-video rounded-md overflow-hidden">
            <img
              src="https://loremflickr.com/1200/675/code,developer,coding?lock=764"
              alt="Schema Markup 적용 검증"
              loading="lazy"
              class="w-full h-full object-cover"
            />
            <div class="absolute top-3 left-3 bg-black/60 backdrop-blur-sm text-white text-xs font-bold px-2 py-1 rounded">02</div>
            <div class="absolute bottom-3 left-3 bg-black/60 backdrop-blur-sm text-white text-xs font-medium px-2 py-1 rounded">🔧 Schema Markup 적용 검증</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. 강점 -->
  <section class="py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">✨ STRENGTHS</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">왜 브랜드 랜딩페이지인가</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {strengths.map((s, i) => (
          <div class={`bg-white border-l-[3px] border-asset p-6 rounded-r-md card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="flex items-center gap-3 mb-3">
              <div class="text-3xl">{s.emoji}</div>
              <div class="text-lg font-bold text-ink-dark">{s.title}</div>
            </div>
            <div class="text-sm text-ink-body leading-relaxed">{s.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. 운영 프로세스 -->
  <section class="bg-bg-light py-16 lg:py-20">
    <div class="container-page max-w-4xl">
      <div class="fade-up">
        <div class="section-eyebrow">⚡ PROCESS</div>
        <h2 class="text-2xl sm:text-3xl font-black text-ink-black mb-10">운영 프로세스</h2>
      </div>
      <div class="space-y-8">
        {process.map((p, i) => (
          <div class={`bg-white border-l-[3px] border-asset p-6 lg:p-8 rounded-r-md card-hover fade-up fade-up-delay-${(i % 3) + 1}`}>
            <div class="flex items-center gap-4 mb-5">
              <div class="inline-flex items-center justify-center w-12 h-12 bg-asset/10 text-asset rounded-full text-xl">{p.emoji}</div>
              <div>
                <div class="font-en text-asset text-xs font-bold tracking-wide-en mb-1">{p.phase}</div>
                <div class="flex items-baseline gap-3">
                  <h3 class="text-lg lg:text-xl font-bold text-ink-dark">{p.title}</h3>
                  <span class="text-xs font-bold text-asset">⏱ {p.period}</span>
                </div>
              </div>
            </div>
            <ul class="space-y-2">
              {p.items.map(it => (
                <li class="text-sm text-ink-body flex gap-2">
                  <span class="text-asset font-bold flex-shrink-0">▸</span>
                  <span>{it}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <CtaBlock 
    title="브랜드 랜딩페이지로 영구 자산을 누적해보세요." 
    sub="워드프레스 반응형 + SEO·AIO 대응 일괄 구축. 견적·운영 옵션을 무료로 안내해드립니다."
    primary="견적 받기" 
    primaryHref="/contact/" 
    secondary="다른 매체 보기"
    secondaryHref="/media/"
  />
</BaseLayout>
