---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBlock from "../../components/CtaBlock.astro";

const categories = [
  { name: "전체", count: 30 },
  { name: "이커머스 인사이트", count: 6 },
  { name: "채널별 운영 가이드", count: 6 },
  { name: "매체 활용법", count: 6 },
  { name: "첫 진입 가이드", count: 6 },
  { name: "AI 검색 시대 대응", count: 6 },
];

// 향후 발행 예정 글 리스트 (Coming Soon)
const posts = [
  { date: "Coming Soon", category: "이커머스 인사이트", title: "이커머스 인사이트 2026 — 올해 주목할 5가지 변화" },
  { date: "Coming Soon", category: "채널별 운영 가이드", title: "네이버 스마트스토어 vs 쿠팡, 어디부터 시작해야 할까" },
  { date: "Coming Soon", category: "이커머스 인사이트", title: "이커머스 운영대행 비용 구조 4가지 — 어떤 옵션이 적합한가" },
  { date: "Coming Soon", category: "첫 진입 가이드", title: "광고비 부담 없이 시작하는 RS 구조란?" },
  { date: "Coming Soon", category: "첫 진입 가이드", title: "F&B 브랜드가 첫 진입 시 꼭 알아야 할 5가지" },
  { date: "Coming Soon", category: "채널별 운영 가이드", title: "건강기능식품 광고법 — 식약처 가이드 핵심 요약" },
  { date: "Coming Soon", category: "채널별 운영 가이드", title: "네이버 SEO 최적화 — 상품명·키워드 작성법" },
  { date: "Coming Soon", category: "채널별 운영 가이드", title: "쿠팡 아이템위너 알고리즘 이해와 대응법" },
  { date: "Coming Soon", category: "매체 활용법", title: "리뷰·후기 자산이 매출에 미치는 영향" },
  { date: "Coming Soon", category: "매체 활용법", title: "인플루언서 vs 블로그 시딩 — 어느 매체가 효율적인가" },
  { date: "Coming Soon", category: "매체 활용법", title: "라이브커머스, 우리 브랜드에 맞을까? 체크리스트" },
  { date: "Coming Soon", category: "AI 검색 시대 대응", title: "나무위키 등록 가이드 — AI 검색 시대의 디지털 평판" },
];
---

<BaseLayout
  title="블로그 — 이커머스 운영 인사이트"
  description="이커머스 운영, 매체 활용, 채널 알고리즘 대응에 관한 실무 인사이트."
  current="/blog/"
>
  <PageHero
    eyebrow="BLOG"
    title="이커머스 운영 인사이트."
    sub="실무에서 바로 활용할 수 있는 운영 노하우, 매체 활용법, 채널 알고리즘 대응법을 정기 발행합니다."
  />

  <!-- 카테고리 필터 -->
  <section class="py-10 border-b border-gray-100">
    <div class="container-page">
      <div class="flex flex-wrap gap-2">
        {categories.map((c, i) => (
          <button class={`px-4 py-2 rounded-full text-sm font-bold transition-colors ${i === 0 ? "bg-red text-white" : "bg-bg-light text-ink-body hover:bg-red/10"}`}>
            {c.name} <span class="opacity-60 ml-1">({c.count})</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- 글 리스트 -->
  <section class="py-16 lg:py-20">
    <div class="container-page">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {posts.map(p => (
          <article class="bg-white rounded-md overflow-hidden border border-gray-100 card-hover cursor-pointer">
            <div class="bg-bg-light h-32 flex items-center justify-center">
              <span class="text-xs font-bold text-ink-light tracking-wide-en">COMING SOON</span>
            </div>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs text-red font-bold">{p.category}</span>
                <span class="text-xs text-ink-light">·</span>
                <span class="text-xs text-ink-mute">{p.date}</span>
              </div>
              <h3 class="text-base font-bold text-ink-dark leading-snug line-clamp-2">
                {p.title}
              </h3>
            </div>
          </article>
        ))}
      </div>
      
      <div class="mt-12 text-center bg-bg-light rounded-md p-8">
        <h3 class="text-lg font-bold text-ink-dark mb-2">블로그 발행 알림 받기</h3>
        <p class="text-sm text-ink-body mb-5">월 2~4편 실무 인사이트를 메일로 받아보세요.</p>
        <form class="flex flex-col sm:flex-row gap-2 max-w-md mx-auto">
          <input type="email" placeholder="이메일 주소" class="flex-1 px-4 py-3 rounded-md border border-gray-300 text-sm focus:outline-none focus:border-red" />
          <button type="submit" class="btn-primary !py-3">구독</button>
        </form>
      </div>
    </div>
  </section>

  <CtaBlock />
</BaseLayout>
